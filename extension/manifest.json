{
  "manifest_version": 3,
  "name": "SoundCloud → Discord Bridge",
  "version": "1.0.0",
  "description": "SoundCloudで再生中の曲を、ローカルブリッジ経由でDiscordのRich Presenceに表示します。",
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["https://soundcloud.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://soundcloud.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "SoundCloud → Discord Bridge",
    "default_popup": "popup.html"
  }
}
